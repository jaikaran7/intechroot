# Local development:
# Must match your backend `PORT` (see intechroot-be `.env`). Vite proxies `/api` here.
VITE_API_URL=http://localhost:5001

# Production:
# In Vercel, set VITE_API_URL to your Railway backend domain.
# Example: VITE_API_URL=https://your-backend.up.railway.app
#
# Optional advanced override if you need the full API base path explicitly.
# Usually leave this unset in Vercel so VITE_API_URL is used.
# VITE_API_BASE_URL=http://localhost:5000/api/v1
